{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MSCQR Secret Rotation Evidence",
  "type": "object",
  "required": [
    "recordedAt",
    "approvedBy",
    "approverRole",
    "reason",
    "ticket",
    "environment",
    "families"
  ],
  "properties": {
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "approvedBy": {
      "type": "string",
      "minLength": 2
    },
    "approverRole": {
      "type": "string",
      "minLength": 2
    },
    "reason": {
      "type": "string",
      "minLength": 6
    },
    "ticket": {
      "type": "string",
      "minLength": 3
    },
    "environment": {
      "type": "string",
      "enum": ["staging", "production", "shared"]
    },
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "rotatedAt", "operator", "method"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2
          },
          "rotatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "operator": {
            "type": "string",
            "minLength": 2
          },
          "method": {
            "type": "string",
            "enum": ["dual-slot", "single-slot-emergency"]
          },
          "evidenceRef": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
