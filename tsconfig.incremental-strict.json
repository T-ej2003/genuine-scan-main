{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/features/dashboard/hooks.ts",
    "src/features/batches/hooks.ts",
    "src/features/printing/hooks.ts",
    "src/features/layout/hooks.ts",
