## Frontend runtime API base
# For Docker + Nginx deployment keep this as /api.
VITE_API_URL=/api

## Docker Compose production deployment
# docker-compose.yml interpolates these from the project root .env (or shell environment)
# before containers start. Set these explicitly on Lightsail/EC2 production hosts.
# For Docker Compose + MinIO, set MINIO_* and OBJECT_STORAGE_* explicitly.
# Keep them aligned unless you intentionally use separate MinIO and application credentials.
# For ECS/Fargate with native AWS S3, set OBJECT_STORAGE_BUCKET plus OBJECT_STORAGE_REGION or AWS_REGION.
# Leave OBJECT_STORAGE_ENDPOINT, OBJECT_STORAGE_ACCESS_KEY, and OBJECT_STORAGE_SECRET_KEY empty to use the task role / default AWS credential chain.
# OBJECT_STORAGE_FORCE_PATH_STYLE=true below is for the Docker Compose + MinIO path. For native AWS S3 task-role mode, omit it or set false in the ECS task definition.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_BUCKET=mscqr-artifacts
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_FORCE_PATH_STYLE=true

## Frontend container ports
FRONTEND_PORT=80
FRONTEND_SSL_PORT=443

## Optional release metadata / Docker build toggles
GIT_SHA=
DOCKER_BUILD_VERIFY=false

## Customer social sign-in on the verify page is now backend-managed.
## Configure the provider client IDs/secrets in backend/.env instead of frontend runtime URLs.

## Vite dev proxy target (used by vite.config.ts server.proxy)
# Keep this pointed at local backend in development.
VITE_API_PROXY_TARGET=http://localhost:4000

## Frontend release metadata and observability
# VITE_APP_ENV should match the deployed environment label you want in logs and Sentry.
VITE_APP_ENV=development
VITE_SENTRY_DSN=
# Optional traces sample rate between 0 and 1.
VITE_SENTRY_SAMPLE_RATE=0
