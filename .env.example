## Frontend runtime API base
# For Docker + Nginx deployment keep this as /api.
VITE_API_URL=/api

## Customer social sign-in on the verify page is now backend-managed.
## Configure the provider client IDs/secrets in backend/.env instead of frontend runtime URLs.

## Vite dev proxy target (used by vite.config.ts server.proxy)
# Keep this pointed at local backend in development.
VITE_API_PROXY_TARGET=http://localhost:4000

## Frontend release metadata and observability
# VITE_APP_ENV should match the deployed environment label you want in logs and Sentry.
VITE_APP_ENV=development
VITE_SENTRY_DSN=
# Optional traces sample rate between 0 and 1.
VITE_SENTRY_SAMPLE_RATE=0
