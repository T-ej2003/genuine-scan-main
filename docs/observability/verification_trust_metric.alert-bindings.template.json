      "destination": "oncall-ops",
      "runbook": "docs/PREMIUM_LAUNCH_INCIDENT_RUNBOOK.md#4-legacy-provenance-anomaly"
    },
    {
      "name": "mscqr-trust-signing-fallback",
      "severity": "high",
      "destination": "oncall-security",
