#############################################
# MSCQR standby env example - Cape Town
#############################################
# Copy to .env.production.capetown on the Cape Town server only.
# The standby deploy playbook copies this file to both .env and backend/.env
# unless backend/.env.production.capetown exists as a separate backend-only file.
# Replace REQUIRED_* placeholders with region-specific secret values.
# Do not commit real secrets.

############
# Compose  #
############
VITE_API_URL=/api
FRONTEND_PORT=80
FRONTEND_SSL_PORT=443
GIT_SHA=
DOCKER_BUILD_VERIFY=false
VITE_APP_ENV=production-capetown-standby
VITE_SENTRY_DSN=
VITE_SENTRY_SAMPLE_RATE=0

############################
# Docker Compose MinIO     #
############################
# Keep these only while this Docker Compose stack uses local MinIO.
# This Phase 2 setup does not clean up or decommission MinIO.
MINIO_ROOT_USER=REQUIRED_CAPETOWN_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=REQUIRED_CAPETOWN_MINIO_ROOT_PASSWORD
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=REQUIRED_CAPETOWN_OBJECT_STORAGE_ACCESS_KEY
OBJECT_STORAGE_SECRET_KEY=REQUIRED_CAPETOWN_OBJECT_STORAGE_SECRET_KEY
OBJECT_STORAGE_BUCKET=mscqr-artifacts-capetown
OBJECT_STORAGE_REGION=af-south-1
AWS_REGION=af-south-1
OBJECT_STORAGE_FORCE_PATH_STYLE=true

################
# Backend      #
################
PORT=4000
NODE_ENV=production
DATABASE_URL=REQUIRED_CAPETOWN_POSTGRES_URL_WITH_SSLMODE_REQUIRE
JWT_SECRET=REQUIRED_CAPETOWN_JWT_SECRET
JWT_SECRET_CURRENT=REQUIRED_CAPETOWN_JWT_SECRET_CURRENT
JWT_SECRET_PREVIOUS=
CORS_ORIGIN=http://YOUR_CAPETOWN_SERVER_IP
COOKIE_DOMAIN=
PUBLIC_SCAN_WEB_BASE_URL=http://YOUR_CAPETOWN_SERVER_IP
PUBLIC_VERIFY_WEB_BASE_URL=http://YOUR_CAPETOWN_SERVER_IP
PUBLIC_ADMIN_WEB_BASE_URL=http://YOUR_CAPETOWN_SERVER_IP
WEB_APP_BASE_URL=http://YOUR_CAPETOWN_SERVER_IP
PUBLIC_API_BASE_URL=
RUN_DB_MIGRATIONS_ON_START=false
RUN_BACKGROUND_WORKERS=false
PUBLIC_VERSION_ENDPOINT_ENABLED=false
ALLOW_BREAK_GLASS_QR_GENERATE=false

#############################
# Signing and security      #
#############################
QR_SIGN_PROVIDER=env
QR_SIGN_PRIVATE_KEY=REQUIRED_CAPETOWN_QR_SIGN_PRIVATE_KEY
QR_SIGN_PUBLIC_KEY=REQUIRED_CAPETOWN_QR_SIGN_PUBLIC_KEY
QR_SIGN_ACTIVE_KEY_VERSION=v1
QR_SIGN_ENFORCE_ED25519_IN_PRODUCTION=true
QR_SIGN_HMAC_SECRET=
QR_SIGN_HMAC_SECRET_CURRENT=
QR_SIGN_HMAC_SECRET_PREVIOUS=
IP_HASH_SALT=REQUIRED_CAPETOWN_IP_HASH_SALT
TOKEN_HASH_SECRET=REQUIRED_CAPETOWN_TOKEN_HASH_SECRET
SCAN_FINGERPRINT_SECRET=REQUIRED_CAPETOWN_SCAN_FINGERPRINT_SECRET
INCIDENT_HASH_SALT=REQUIRED_CAPETOWN_INCIDENT_HASH_SALT
PRINTER_SSE_SIGN_SECRET=REQUIRED_CAPETOWN_PRINTER_SSE_SIGN_SECRET
CUSTOMER_VERIFY_OTP_SECRET=REQUIRED_CAPETOWN_CUSTOMER_VERIFY_OTP_SECRET
CUSTOMER_VERIFY_TOKEN_SECRET=REQUIRED_CAPETOWN_CUSTOMER_VERIFY_TOKEN_SECRET
CUSTOMER_VERIFY_OAUTH_STATE_SECRET=
CUSTOMER_VERIFY_OAUTH_EXCHANGE_SECRET=

#############################
# Production posture        #
#############################
COOKIE_SECURE=false
VERIFY_REPLAY_HARDENING_ENABLED=true
VERIFY_SESSION_PROOF_BINDING_REQUIRED=true
VERIFY_REQUIRE_GOVERNED_PRINT_PROVENANCE=true
VERIFY_OBSERVABILITY_LOGGING_ENABLED=true
VERIFY_CUSTOMER_COOKIE_AUTH_ENABLED=true
VERIFY_CUSTOMER_BEARER_COMPAT_ENABLED=false
AUDIT_LOG_STORE_RAW_IP=false
SUPER_ADMIN_BOOTSTRAP_ENABLED=false
SUPER_ADMIN_BOOTSTRAP_PASSWORD=
SUPER_ADMIN_BOOTSTRAP_AUTO_VERIFY=false
EMAIL_USE_JSON_TRANSPORT=false

#############################
# Email and integrations    #
#############################
SMTP_HOST=REQUIRED_CAPETOWN_SMTP_HOST
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=REQUIRED_CAPETOWN_SMTP_USER
SMTP_PASS=REQUIRED_CAPETOWN_SMTP_PASS
SUPER_ADMIN_EMAIL=REQUIRED_SUPER_ADMIN_EMAIL
SUPERADMIN_ALERT_EMAILS=REQUIRED_ALERT_EMAILS
CUSTOMER_VERIFY_GOOGLE_CLIENT_ID=
CUSTOMER_VERIFY_GOOGLE_CLIENT_SECRET=
SENTRY_ENVIRONMENT=production-capetown-standby
