{
  "name": "genuine-scan-console",
  "private": true,
  "version": "1.0.0",
  "description": "Frontend console for the Genuine Scan QR authenticity platform.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "docs:docx": "npm run docs:printing:images && node scripts/generate-user-manual-docx.mjs",
    "docs:docx:printing": "npm run docs:printing:images && node scripts/generate-printing-docx.mjs",
    "docs:docx:roles": "node scripts/generate-user-manual-docx.mjs",
    "docs:meeting": "node scripts/capture-role-manual-screenshots.mjs && node scripts/generate-meeting-role-manual-docx.mjs",
    "docs:meeting:docx": "node scripts/generate-meeting-role-manual-docx.mjs",
    "docs:meeting:screenshots": "node scripts/capture-role-manual-screenshots.mjs",
    "docs:printing:images": "node scripts/generate-printing-doc-images.mjs",
    "docs:screenshots": "playwright test scripts/docs-screenshots.spec.ts && npm run docs:printing:images",
    "check:budgets": "node scripts/check-code-size.mjs",
    "check:dependency-audit": "node scripts/check-dependency-audit.mjs",
    "check:cloudwatch-config": "node scripts/observability/validate-cloudwatch-config.mjs",
    "check:nginx-hardening": "node scripts/check-nginx-hardening.mjs",
    "check:customer-auth-cutover": "node scripts/check-customer-auth-cutover.mjs",
    "check:public-metadata-surface": "node scripts/check-public-metadata-surface.mjs",
    "check:release-evidence-refs": "node scripts/check-release-evidence-refs.mjs",
    "check:release-governance": "node scripts/check-release-governance.mjs",
    "check:rotation-evidence": "node scripts/check-rotation-evidence.mjs",
    "check:rotation-cleanup": "node scripts/check-rotation-cleanup.mjs",
    "check:security-guardrails": "node scripts/check-security-guardrails.mjs",
    "check:trust-alert-bindings": "node scripts/check-trust-alert-bindings.mjs",
    "check:trust-observability": "node scripts/check-trust-observability.mjs",
    "lint": "eslint .",
    "lint:changed": "node scripts/lint-changed.mjs",
    "lint:debt:report": "node scripts/lint-debt-report.mjs",
    "preview": "vite preview",
    "smoke:release": "node scripts/smoke-release.mjs",
    "smoke:dev-local": "SMOKE_ALLOW_LOCAL_DEFAULT=true node scripts/smoke-release.mjs",
    "test": "vitest run",
    "test:trust-critical": "vitest run src/test/verify-page.test.tsx && npm --prefix backend run test:trust-critical",
    "test:e2e": "playwright test --config=playwright.enterprise.config.ts",
    "test:e2e:headed": "playwright test --config=playwright.enterprise.config.ts --headed",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:incremental": "npm run typecheck",
    "verify:rc-local": "npm run check:security-guardrails && npm run check:dependency-audit && npm run check:trust-observability && npm run check:trust-alert-bindings && npm run check:cloudwatch-config && npm run check:rotation-evidence && npm run check:rotation-cleanup && npm run check:customer-auth-cutover && npm run check:nginx-hardening && npm run check:public-metadata-surface && npm run typecheck && npm run build && npm run test:trust-critical",
    "verify:staging-smoke": "node scripts/verify-staging-smoke.mjs",
    "backfill:provenance:dry-run": "node scripts/backfill-provenance-artifact.mjs",
    "backfill:provenance:execute": "node scripts/backfill-provenance-artifact.mjs --execute",
    "verify:release": "npm run check:security-guardrails && npm run check:dependency-audit && npm run check:trust-observability && npm run check:trust-alert-bindings && npm run check:cloudwatch-config && npm run check:rotation-evidence && npm run check:rotation-cleanup && npm run check:customer-auth-cutover && npm run check:nginx-hardening && npm run check:public-metadata-surface && npm run check:release-evidence-refs && npm run typecheck && npm run build && npm run test:trust-critical && npm test && npm --prefix backend run prisma:generate && (cd backend && npm test)"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@sentry/react": "^10.45.0",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.21",
    "docx": "^9.5.3",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
