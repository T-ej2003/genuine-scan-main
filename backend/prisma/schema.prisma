  qrCodeValue String

  scanEventId String?
  scanEvent   QrScanLog? @relation(fields: [scanEventId], references: [id])

  licenseeId String?
  licensee   Licensee? @relation(fields: [licenseeId], references: [id])

  reportedBy IncidentReportedBy @default(CUSTOMER)
  customerName String?
  customerEmail String?
  customerPhone String?
  customerCountry String?
  preferredContactMethod IncidentContactMethod @default(NONE)
  consentToContact Boolean @default(false)

  incidentType IncidentType
  severity IncidentSeverity @default(MEDIUM)
  severityOverridden Boolean @default(false)
  description String
