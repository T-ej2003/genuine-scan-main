generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  LICENSEE_ADMIN
  MANUFACTURER
}

enum QRStatus {
  DORMANT
  ACTIVE
  ALLOCATED
  ACTIVATED
  PRINTED
  REDEEMED
  BLOCKED
  SCANNED
}

enum QrAllocationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PrintJobStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole
  location     String?
  website      String?

  licenseeId String?
  licensee   Licensee? @relation(fields: [licenseeId], references: [id])

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  assignedBatches        Batch[]        @relation("ManufacturerBatches")

  qrAllocationRequestsRequested QrAllocationRequest[] @relation("QrAllocationRequestedBy")
  qrAllocationRequestsApproved  QrAllocationRequest[] @relation("QrAllocationApprovedBy")
  qrAllocationRequestsRejected  QrAllocationRequest[] @relation("QrAllocationRejectedBy")

  allocationEventsCreated AllocationEvent[] @relation("AllocationEventCreatedBy")
  batchPrintPackTokensCreated BatchPrintPackToken[] @relation("BatchPrintPackTokenCreatedBy")
  batchPrintDownloads Batch[] @relation("BatchPrintPackDownloadedBy")
  printedQRCodes QRCode[] @relation("QRCodePrintedBy")
  printJobs PrintJob[] @relation("ManufacturerPrintJobs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
  @@index([role])
  @@index([isActive])
}

model Licensee {
  id          String  @id @default(uuid())
  name        String
  prefix      String  @unique
  description String?
  brandName   String?
  location    String?
  website     String?
  supportEmail String?
  supportPhone String?
  isActive    Boolean @default(true)

  users          User[]
  qrRanges       QRRange[]
  batches        Batch[]
  qrCodes        QRCode[]
  qrAllocationRequests QrAllocationRequest[]
  allocationEvents     AllocationEvent[]
  qrScanLogs           QrScanLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model QRRange {
  id         String   @id @default(uuid())
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  startCode  String
  endCode    String
  totalCodes Int
  usedCodes  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
}

model Batch {
  id         String   @id @default(uuid())
  name       String
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  // legacy optional direct assignment
  manufacturerId String?
  manufacturer   User?   @relation("ManufacturerBatches", fields: [manufacturerId], references: [id])

  startCode  String
  endCode    String
  totalCodes Int
  printedAt  DateTime?
  printPackDownloadedAt DateTime?
  printPackDownloadedByUserId String?
  printPackDownloadedByUser   User? @relation("BatchPrintPackDownloadedBy", fields: [printPackDownloadedByUserId], references: [id])

  qrCodes        QRCode[]
  batchPrintPackTokens BatchPrintPackToken[]
  printJobs          PrintJob[]
  scanLogs            QrScanLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
  @@index([manufacturerId])
  @@index([printedAt])
  @@index([printPackDownloadedAt])
}

model PrintJob {
  id         String   @id @default(uuid())
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id])

  manufacturerId String
  manufacturer   User   @relation("ManufacturerPrintJobs", fields: [manufacturerId], references: [id])

  status     PrintJobStatus @default(PENDING)
  quantity   Int
  rangeStart String?
  rangeEnd   String?

  printLockTokenHash String @unique
  confirmedAt DateTime?
  createdAt   DateTime @default(now())

  qrCodes QRCode[]

  @@index([batchId])
  @@index([manufacturerId])
  @@index([status])
}

model QRCode {
  id         String   @id @default(uuid())
  code       String   @unique
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  // product batch removed
  scanLogs       QrScanLog[]

  status    QRStatus  @default(DORMANT)
  scannedAt DateTime?
  scanCount Int       @default(0)
  printedAt DateTime?
  printedByUserId String?
  printedByUser   User? @relation("QRCodePrintedBy", fields: [printedByUserId], references: [id])
  redeemedAt DateTime?
  redeemedDeviceFingerprint String?
  lastScanIp String?
  lastScanUserAgent String?
  lastScanDevice String?
  blockedAt DateTime?
  tokenNonce String?
  tokenIssuedAt DateTime?
  tokenExpiresAt DateTime?
  tokenHash String?

  printJobId String?
  printJob   PrintJob? @relation(fields: [printJobId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
  @@index([batchId])
  @@index([status])
  @@index([printJobId])
  @@index([tokenHash])
}

model QrScanLog {
  id         String   @id @default(uuid())
  code       String
  qrCodeId   String
  qrCode     QRCode   @relation(fields: [qrCodeId], references: [id])

  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  batchId String?
  batch   Batch? @relation(fields: [batchId], references: [id])
  // product batch removed

  status     QRStatus
  scannedAt  DateTime @default(now())
  isFirstScan Boolean @default(false)
  scanCount  Int?

  ipAddress String?
  userAgent String?
  device    String?
  latitude  Float?
  longitude Float?
  accuracy  Float?

  @@index([licenseeId])
  @@index([batchId])
  @@index([code])
  @@index([scannedAt])
}

model BatchPrintPackToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id])

  createdByUserId String
  createdByUser   User @relation("BatchPrintPackTokenCreatedBy", fields: [createdByUserId], references: [id])

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([batchId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  licenseeId String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([licenseeId])
  @@index([entityType])
  @@index([createdAt])
}

model QrAllocationRequest {
  id         String   @id @default(uuid())
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  requestedByUserId String
  requestedByUser   User @relation("QrAllocationRequestedBy", fields: [requestedByUserId], references: [id])

  quantity    Int?
  startNumber Int?
  endNumber   Int?

  status QrAllocationRequestStatus @default(PENDING)
  note   String?

  approvedByUserId String?
  approvedByUser   User? @relation("QrAllocationApprovedBy", fields: [approvedByUserId], references: [id])
  approvedAt       DateTime?

  rejectedByUserId String?
  rejectedByUser   User? @relation("QrAllocationRejectedBy", fields: [rejectedByUserId], references: [id])
  rejectedAt       DateTime?

  decisionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  allocationEvents AllocationEvent[]

  @@index([licenseeId])
  @@index([status])
}

model AllocationEvent {
  id         String   @id @default(uuid())
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  createdByUserId String?
  createdByUser   User? @relation("AllocationEventCreatedBy", fields: [createdByUserId], references: [id])

  requestId String?
  request   QrAllocationRequest? @relation(fields: [requestId], references: [id])

  source     String?
  startCode  String
  endCode    String
  totalCodes Int

  createdAt DateTime @default(now())

  @@index([licenseeId])
  @@index([requestId])
}
