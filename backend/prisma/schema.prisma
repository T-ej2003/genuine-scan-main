generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  LICENSEE_ADMIN
  MANUFACTURER
  // New RBAC roles (preferred). Legacy roles remain for backward compatibility.
  PLATFORM_SUPER_ADMIN
  ORG_ADMIN
  MANUFACTURER_ADMIN
  MANUFACTURER_USER
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum QRStatus {
  DORMANT
  ACTIVE
  ALLOCATED
  ACTIVATED
  PRINTED
  REDEEMED
  BLOCKED
  SCANNED
}

enum QrAllocationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PrintJobStatus {
  PENDING
  SENT
  CONFIRMED
  FAILED
  CANCELLED
}

enum PrinterConnectionType {
  LOCAL_AGENT
  NETWORK_DIRECT
  NETWORK_IPP
}

enum PrinterCommandLanguage {
  AUTO
  ZPL
  TSPL
  SBPL
  EPL
  DPL
  HONEYWELL_DP
  HONEYWELL_FINGERPRINT
  IPL
  ZSIM
  CPCL
  ESC_POS
  OTHER
}

enum PrinterTransportKind {
  RAW_TCP
  USB_RAW
  SERIAL_RAW
  DRIVER_QUEUE
  SITE_GATEWAY
  VENDOR_SDK
  WEB_API
}

enum PrinterLanguageKind {
  AUTO
  ZPL
  EPL
  TSPL
  DPL
  SBPL
  HONEYWELL_DP
  HONEYWELL_FINGERPRINT
  IPL
  ZSIM
  PDF
  OTHER
}

enum PrinterProfileStatus {
  DRAFT
  CERTIFIED
  NEEDS_REVIEW
  BLOCKED
}

enum PrinterProfileSnapshotType {
  ONBOARDING
  LIVE_DISCOVERY
  CERTIFICATION_TEST
}

enum PrintDispatchMode {
  LOCAL_AGENT
  NETWORK_DIRECT
  NETWORK_IPP
}

enum PrintPayloadType {
  PDF
  ZPL
  TSPL
  SBPL
  EPL
  DPL
  HONEYWELL_DP
  HONEYWELL_FINGERPRINT
  IPL
  CPCL
  ESC_POS
  JSON
  OTHER
}

enum PrinterDeliveryMode {
  DIRECT
  SITE_GATEWAY
}

enum PrintSessionStatus {
  ACTIVE
  FAILED
  COMPLETED
  CANCELLED
}

enum PrintItemState {
  RESERVED
  ISSUED
  AGENT_ACKED
  PRINT_CONFIRMED
  CLOSED
  FROZEN
  FAILED
}

enum PrintPipelineState {
  QUEUED
  PREFLIGHT_OK
  SENT_TO_PRINTER
  PRINTER_ACKNOWLEDGED
  PRINT_CONFIRMED
  LOCKED
  FAILED
  NEEDS_OPERATOR_ACTION
}

enum PrintItemEventType {
  RESERVED
  ISSUED
  AGENT_ACKED
  PRINT_CONFIRMED
  CLOSED
  FROZEN
  FAILED
  INCIDENT_RAISED
}

enum PrinterTrustStatus {
  PENDING
  TRUSTED
  REVOKED
  FAILED
}

enum ReissueRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  CANCELLED
}

enum OwnershipTransferStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

enum ForensicEventType {
  PRINT_ISSUANCE
  PRINT_CONFIRM
  SCAN_VERIFY
  SECURITY_BLOCK
}

enum TraceEventType {
  COMMISSIONED
  ASSIGNED
  PRINTED
  REDEEMED
  BLOCKED
}

enum PolicyAlertType {
  MULTI_SCAN
  GEO_DRIFT
  VELOCITY_SPIKE
  STUCK_BATCH
  AUTO_BLOCK_QR
  AUTO_BLOCK_BATCH
  POLICY_RULE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PolicyRuleType {
  DISTINCT_DEVICES
  MULTI_COUNTRY
  BURST_SCANS
  TOO_MANY_REPORTS
}

enum IncidentReportedBy {
  CUSTOMER
  LICENSEE
  ADMIN
}

enum IncidentContactMethod {
  EMAIL
  PHONE
  WHATSAPP
  NONE
}

enum IncidentType {
  COUNTERFEIT_SUSPECTED
  DUPLICATE_SCAN
  TAMPERED_LABEL
  WRONG_PRODUCT
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  NEW
  TRIAGED
  TRIAGE
  INVESTIGATING
  CONTAINMENT
  ERADICATION
  RECOVERY
  AWAITING_CUSTOMER
  AWAITING_LICENSEE
  MITIGATED
  RESOLVED
  CLOSED
  REOPENED
  REJECTED_SPAM
}

enum IncidentPriority {
  P1
  P2
  P3
  P4
}

enum IncidentResolutionOutcome {
  CONFIRMED_FRAUD
  NOT_FRAUD
  INCONCLUSIVE
}

enum IncidentActorType {
  CUSTOMER
  ADMIN
  SYSTEM
}

enum IncidentEventType {
  CREATED
  UPDATED_FIELDS
  STATUS_CHANGED
  ASSIGNED
  EMAIL_SENT
  NOTE_ADDED
  EVIDENCE_ADDED
  EXPORTED
}

enum IncidentCommDirection {
  OUTBOUND
  INBOUND
}

enum IncidentCommChannel {
  EMAIL
}

enum IncidentCommStatus {
  QUEUED
  SENT
  FAILED
}

enum IncidentHandoffStage {
  INTAKE
  REVIEW
  CONTAINMENT
  DOCUMENTATION
  RESOLUTION
  COMPLETE
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum NotificationChannel {
  WEB
  EMAIL
}

enum NotificationAudience {
  SUPER_ADMIN
  LICENSEE_ADMIN
  MANUFACTURER
  ALL
}

enum EvidenceRetentionJobStatus {
  RUNNING
  COMPLETED
  FAILED
  PREVIEW
}

enum AuthRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SecurityEventDeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum CompliancePackJobStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum VerificationDecisionOutcome {
  AUTHENTIC
  SUSPICIOUS_DUPLICATE
  BLOCKED
  NOT_READY
  NOT_FOUND
  INVALID_SIGNATURE
  INVALID_PAYLOAD
  EXPIRED
  TOKEN_MISMATCH
  UNAVAILABLE
}

enum VerificationProofTier {
  SIGNED_LABEL
  MANUAL_REGISTRY_LOOKUP
  DEGRADED
}

enum VerificationRiskBand {
  LOW
  ELEVATED
  HIGH
  CRITICAL
}

enum VerificationReplacementStatus {
  NONE
  ACTIVE_REPLACEMENT
  REPLACED_LABEL
}

enum VerificationDegradationMode {
  NORMAL
  QUEUE_AND_RETRY
  FAIL_CLOSED
}

enum CustomerTrustLevel {
  ANONYMOUS
  DEVICE_TRUSTED
  ACCOUNT_TRUSTED
  PASSKEY_VERIFIED
  OPERATOR_REVIEWED
}

enum CustomerTrustReviewState {
  UNREVIEWED
  VERIFIED
  DISPUTED
  REVOKED
}

enum ReplacementChainStatus {
  ACTIVE
  SUPERSEDED
}

enum AuditLogOutboxStatus {
  QUEUED
  SENT
  FAILED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  pendingEmail String?  @unique
  passwordHash String?
  name         String
  role         UserRole
  location     String?
  website      String?

  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id])

  licenseeId String?
  licensee   Licensee? @relation(fields: [licenseeId], references: [id])
  manufacturerLicenseeLinks ManufacturerLicenseeLink[] @relation("ManufacturerLicenseeLinks")

  status   UserStatus @default(ACTIVE)
  isActive  Boolean   @default(true)
  disabledAt DateTime?
  disabledReason String?
  deletedAt DateTime?

  failedLoginAttempts Int @default(0)
  lockedUntil DateTime?
  lastLoginAt DateTime?
  emailVerifiedAt DateTime?
  pendingEmailRequestedAt DateTime?

  assignedBatches        Batch[]        @relation("ManufacturerBatches")

  qrAllocationRequestsRequested QrAllocationRequest[] @relation("QrAllocationRequestedBy")
  qrAllocationRequestsApproved  QrAllocationRequest[] @relation("QrAllocationApprovedBy")
  qrAllocationRequestsRejected  QrAllocationRequest[] @relation("QrAllocationRejectedBy")

  allocationEventsCreated AllocationEvent[] @relation("AllocationEventCreatedBy")
  batchPrintPackTokensCreated BatchPrintPackToken[] @relation("BatchPrintPackTokenCreatedBy")
  batchPrintDownloads Batch[] @relation("BatchPrintPackDownloadedBy")
  printedQRCodes QRCode[] @relation("QRCodePrintedBy")
  printJobs PrintJob[] @relation("ManufacturerPrintJobs")
  printSessions PrintSession[] @relation("ManufacturerPrintSessions")
  printerRegistrations PrinterRegistration[] @relation("PrinterRegistrations")
  printersCreated Printer[] @relation("PrinterCreatedBy")
  assignedPrinters Printer[] @relation("PrinterAssignedUser")
  approvedPrintJobs PrintJob[] @relation("PrintJobApprovedBy")
  requestedPrintReissues PrintReissueRequest[] @relation("PrintReissueRequestedBy")
  approvedPrintReissues PrintReissueRequest[] @relation("PrintReissueApprovedBy")
  printItemEvents PrintItemEvent[] @relation("PrintItemEventActor")
  traceEventsAsActor TraceEvent[] @relation("TraceEventUser")
  traceEventsAsManufacturer TraceEvent[] @relation("TraceEventManufacturer")
  policyAlertsAsManufacturer PolicyAlert[] @relation("PolicyAlertManufacturer")
  policyAlertsAcknowledged PolicyAlert[] @relation("PolicyAlertAcknowledgedBy")
  assignedIncidents Incident[] @relation("IncidentAssignedTo")
  incidentEvents IncidentEvent[] @relation("IncidentActorUser")
  incidentEvidence IncidentEvidence[] @relation("IncidentEvidenceUploadedBy")
  supportTicketsAssigned SupportTicket[] @relation("SupportTicketAssignedTo")
  supportTicketMessages SupportTicketMessage[] @relation("SupportTicketMessageAuthor")
  supportIssueReportsSubmitted SupportIssueReport[] @relation("SupportIssueReportSubmittedBy")
  supportIssueReportsResponded SupportIssueReport[] @relation("SupportIssueReportRespondedBy")
  notifications Notification[] @relation("UserNotifications")
  tenantFeatureFlagsUpdated TenantFeatureFlag[] @relation("TenantFeatureFlagUpdatedBy")
  evidenceRetentionPoliciesUpdated EvidenceRetentionPolicy[] @relation("EvidenceRetentionPolicyUpdatedBy")
  evidenceRetentionJobsStarted EvidenceRetentionJob[] @relation("EvidenceRetentionJobStartedBy")
  compliancePackJobsStarted CompliancePackJob[] @relation("CompliancePackJobStartedBy")
  routeTransitionMetrics RouteTransitionMetric[] @relation("RouteTransitionMetricUser")

  invitesCreated Invite[] @relation("InviteCreatedBy")
  invitesAccepted Invite[] @relation("InviteAcceptedBy")
  passwordResets PasswordReset[]
  emailVerificationTokens EmailVerificationToken[]
  refreshTokens RefreshToken[]
  adminMfaCredential AdminMfaCredential?
  adminWebAuthnCredentials AdminWebAuthnCredential[]
  authMfaChallenges AuthMfaChallenge[]
  authWebAuthnChallenges AuthWebAuthnChallenge[]
  authSessionRiskSignals AuthSessionRiskSignal[]
  policyRulesCreated PolicyRule[] @relation("PolicyRuleCreatedBy")
  sensitiveActionApprovalsRequested SensitiveActionApproval[] @relation("SensitiveActionApprovalRequestedBy")
  sensitiveActionApprovalsReviewed SensitiveActionApproval[] @relation("SensitiveActionApprovalReviewedBy")
  sensitiveActionApprovalsExecuted SensitiveActionApproval[] @relation("SensitiveActionApprovalExecutedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([licenseeId])
  @@index([role])
  @@index([isActive])
  @@index([status])
  @@index([lockedUntil])
  @@index([emailVerifiedAt])
}

model Organization {
  id       String @id @default(uuid())
  name     String
  isActive Boolean @default(true)

  licensee Licensee?
  users    User[]
  invites  Invite[]
  passwordResets PasswordReset[]
  refreshTokens  RefreshToken[]
  auditLogs AuditLog[]
  policyRules PolicyRule[]
  notifications Notification[]
  printerRegistrations PrinterRegistration[]
  printers Printer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Licensee {
  id          String  @id @default(uuid())
  orgId       String  @unique
  organization Organization @relation(fields: [orgId], references: [id])

  name        String
  prefix      String  @unique
  description String?
  brandName   String?
  location    String?
  website     String?
  supportEmail String?
  supportPhone String?
  isActive    Boolean @default(true)
  suspendedAt DateTime?
  suspendedReason String?

  users          User[]
  manufacturerLinks ManufacturerLicenseeLink[] @relation("LicenseeManufacturerLinks")
  qrRanges       QRRange[]
  batches        Batch[]
  qrCodes        QRCode[]
  qrAllocationRequests QrAllocationRequest[]
  allocationEvents     AllocationEvent[]
  qrScanLogs           QrScanLog[]
  traceEvents          TraceEvent[]
  securityPolicies     SecurityPolicy[]
  policyRules          PolicyRule[]
  policyAlerts         PolicyAlert[]
  incidents            Incident[]
  invites              Invite[]
  notifications        Notification[]
  tenantFeatureFlags   TenantFeatureFlag[]
  supportTickets       SupportTicket[]
  supportIssueReports  SupportIssueReport[]
  evidenceRetentionPolicy EvidenceRetentionPolicy?
  evidenceRetentionJobs EvidenceRetentionJob[]
  compliancePackJobs CompliancePackJob[]
  routeTransitionMetrics RouteTransitionMetric[]
  printerRegistrations PrinterRegistration[]
  printers Printer[]
  forensicEventChainEntries ForensicEventChain[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([orgId])
}

model ManufacturerLicenseeLink {
  manufacturerId String
  manufacturer   User @relation("ManufacturerLicenseeLinks", fields: [manufacturerId], references: [id], onDelete: Cascade)

  licenseeId String
  licensee   Licensee @relation("LicenseeManufacturerLinks", fields: [licenseeId], references: [id], onDelete: Cascade)

  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([manufacturerId, licenseeId])
  @@index([licenseeId])
  @@index([manufacturerId, isPrimary])
}

model QRRange {
  id         String   @id @default(uuid())
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  startCode  String
  endCode    String
  totalCodes Int
  usedCodes  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
}

model Batch {
  id         String   @id @default(uuid())
  name       String
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  // legacy optional direct assignment
  manufacturerId String?
  manufacturer   User?   @relation("ManufacturerBatches", fields: [manufacturerId], references: [id])

  parentBatchId String?
  parentBatch   Batch?   @relation("BatchAllocationLineage", fields: [parentBatchId], references: [id], onDelete: SetNull)
  allocatedBatches Batch[] @relation("BatchAllocationLineage")

  rootBatchId String?
  rootBatch   Batch?   @relation("BatchAllocationRoot", fields: [rootBatchId], references: [id], onDelete: SetNull)
  allocationScopeBatches Batch[] @relation("BatchAllocationRoot")

  startCode  String
  endCode    String
  totalCodes Int
  printedAt  DateTime?
  suspendedAt DateTime?
  suspendedReason String?
  printPackDownloadedAt DateTime?
  printPackDownloadedByUserId String?
  printPackDownloadedByUser   User? @relation("BatchPrintPackDownloadedBy", fields: [printPackDownloadedByUserId], references: [id])

  qrCodes        QRCode[]
  batchPrintPackTokens BatchPrintPackToken[]
  printJobs          PrintJob[]
  printSessions      PrintSession[]
  scanLogs            QrScanLog[]
  traceEvents         TraceEvent[]
  policyAlerts        PolicyAlert[]
  inventoryRollup     InventoryStatusRollup?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
  @@index([manufacturerId])
  @@index([parentBatchId])
  @@index([rootBatchId])
  @@index([printedAt])
  @@index([printPackDownloadedAt])
  @@index([suspendedAt])
}

model InventoryStatusRollup {
  batchId String @id
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  licenseeId String
  manufacturerId String?

  totalCodes Int @default(0)
  dormant Int @default(0)
  active Int @default(0)
  activated Int @default(0)
  allocated Int @default(0)
  printed Int @default(0)
  redeemed Int @default(0)
  blocked Int @default(0)
  scanned Int @default(0)

  refreshedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId, refreshedAt])
  @@index([manufacturerId, refreshedAt])
}

model PrintJob {
  id         String   @id @default(uuid())
  jobNumber  String?  @unique
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id])

  manufacturerId String
  manufacturer   User   @relation("ManufacturerPrintJobs", fields: [manufacturerId], references: [id])

  printerId String?
  printer Printer? @relation(fields: [printerId], references: [id], onDelete: SetNull)

  status     PrintJobStatus @default(PENDING)
  printMode  PrintDispatchMode @default(LOCAL_AGENT)
  pipelineState PrintPipelineState @default(QUEUED)
  payloadType PrintPayloadType?
  payloadHash String?
  quantity   Int
  itemCount Int?
  rangeStart String?
  rangeEnd   String?
  sentAt DateTime?
  completedAt DateTime?
  failureReason String?

  reprintOfJobId String?
  reprintOfJob PrintJob? @relation("PrintJobReprints", fields: [reprintOfJobId], references: [id], onDelete: SetNull)
  reprintJobs PrintJob[] @relation("PrintJobReprints")

  approvedByUserId String?
  approvedByUser User? @relation("PrintJobApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  reprintReason String?

  printLockTokenHash String? @unique
  confirmedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrCodes QRCode[]
  renderTokens PrintRenderToken[]
  printSession PrintSession?
  reissueRequests PrintReissueRequest[] @relation("OriginalPrintJobReissueRequests")
  replacementForReissueRequest PrintReissueRequest? @relation("ReplacementPrintJobReissueRequest")

  @@index([batchId])
  @@index([manufacturerId])
  @@index([printerId])
  @@index([printMode, status])
  @@index([pipelineState])
  @@index([status])
  @@index([reprintOfJobId])
}

model QRCode {
  id         String   @id @default(uuid())
  code       String   @unique
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  // product batch removed
  scanLogs       QrScanLog[]

  status    QRStatus  @default(DORMANT)
  scannedAt DateTime?
  scanCount Int       @default(0)
  printedAt DateTime?
  printedByUserId String?
  printedByUser   User? @relation("QRCodePrintedBy", fields: [printedByUserId], references: [id])
  redeemedAt DateTime?
  redeemedDeviceFingerprint String?
  lastScanIp String?
  lastScanUserAgent String?
  lastScanDevice String?
  blockedAt DateTime?
  underInvestigationAt DateTime?
  underInvestigationReason String?
  tokenNonce String?
  tokenIssuedAt DateTime?
  tokenExpiresAt DateTime?
  tokenHash String?

  printJobId String?
  printJob   PrintJob? @relation(fields: [printJobId], references: [id])
  renderTokens PrintRenderToken[]
  printItem PrintItem?
  traceEvents TraceEvent[]
  policyAlerts PolicyAlert[]
  incidents Incident[]
  ownership Ownership?
  ownershipTransfers OwnershipTransfer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
  @@index([batchId])
  @@index([status])
  @@index([printJobId])
  @@index([tokenHash])
  @@index([underInvestigationAt])
  @@index([licenseeId, batchId, status])
  @@index([licenseeId, status, updatedAt])
}

model PrintRenderToken {
  id String @id @default(uuid())

  tokenHash String @unique
  printJobId String
  printJob PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)

  qrCodeId String
  qrCode QRCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  usedAt DateTime?
  createdAt DateTime @default(now())

  @@index([printJobId, createdAt])
  @@index([qrCodeId, createdAt])
  @@index([expiresAt])
  @@index([usedAt])
}

model PrintSession {
  id String @id @default(uuid())

  printJobId String @unique
  printJob PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)

  batchId String
  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  manufacturerId String
  manufacturer User @relation("ManufacturerPrintSessions", fields: [manufacturerId], references: [id], onDelete: Cascade)

  printerRegistrationId String?
  printerRegistration PrinterRegistration? @relation(fields: [printerRegistrationId], references: [id], onDelete: SetNull)

  printerId String?
  printer Printer? @relation(fields: [printerId], references: [id], onDelete: SetNull)

  status PrintSessionStatus @default(ACTIVE)
  totalItems Int
  issuedItems Int @default(0)
  confirmedItems Int @default(0)
  frozenItems Int @default(0)
  failedReason String?
  startedAt DateTime @default(now())
  completedAt DateTime?

  items PrintItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([manufacturerId, status])
  @@index([batchId, status])
  @@index([printerRegistrationId])
  @@index([printerId])
}

model PrintItem {
  id String @id @default(uuid())

  printSessionId String
  printSession PrintSession @relation(fields: [printSessionId], references: [id], onDelete: Cascade)

  qrCodeId String @unique
  qrCode QRCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  code String
  state PrintItemState @default(RESERVED)
  pipelineState PrintPipelineState @default(QUEUED)
  issueSequence Int?
  attemptCount Int @default(0)
  currentRenderTokenHash String?
  deviceJobRef String?
  dispatchMetadata Json?
  confirmationEvidence Json?

  issuedAt DateTime?
  dispatchedAt DateTime?
  agentAckedAt DateTime?
  confirmationDeadlineAt DateTime?
  printConfirmedAt DateTime?
  closedAt DateTime?
  frozenAt DateTime?
  failedAt DateTime?
  failureReason String?
  deadLetterReason String?

  events PrintItemEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([printSessionId, state, issueSequence])
  @@index([state, updatedAt])
  @@index([pipelineState, updatedAt])
  @@index([currentRenderTokenHash])
  @@index([deviceJobRef])
  @@index([confirmationDeadlineAt, state])
}

model PrintItemEvent {
  id String @id @default(uuid())

  printItemId String
  printItem PrintItem @relation(fields: [printItemId], references: [id], onDelete: Cascade)

  eventType PrintItemEventType
  previousState PrintItemState?
  nextState PrintItemState?
  details Json?

  actorUserId String?
  actorUser User? @relation("PrintItemEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([printItemId, createdAt])
  @@index([eventType, createdAt])
  @@index([actorUserId, createdAt])
}

model PrinterRegistration {
  id String @id @default(uuid())

  userId String
  user User @relation("PrinterRegistrations", fields: [userId], references: [id], onDelete: Cascade)

  orgId String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  licenseeId String?
  licensee Licensee? @relation(fields: [licenseeId], references: [id], onDelete: SetNull)

  deviceFingerprint String
  agentId String
  publicKeyPem String
  certFingerprint String?

  trustStatus PrinterTrustStatus @default(PENDING)
  trustReason String?
  approvedAt DateTime?
  revokedAt DateTime?
  lastSeenAt DateTime?

  attestations PrinterAttestation[]
  printSessions PrintSession[]
  printers Printer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, deviceFingerprint])
  @@index([agentId])
  @@index([trustStatus, lastSeenAt])
  @@index([licenseeId, trustStatus])
  @@index([orgId, trustStatus])
}

model Printer {
  id String @id @default(uuid())

  name String
  vendor String?
  model String?

  connectionType PrinterConnectionType
  commandLanguage PrinterCommandLanguage @default(AUTO)

  ipAddress String?
  host String?
  port Int?
  resourcePath String?
  tlsEnabled Boolean @default(false)
  printerUri String?
  deliveryMode PrinterDeliveryMode @default(DIRECT)
  gatewayId String?
  gatewaySecretHash String?
  gatewayLastSeenAt DateTime?
  gatewayStatus String?
  gatewayLastError String?

  nativePrinterId String?
  agentId String?
  deviceFingerprint String?

  printerRegistrationId String?
  printerRegistration PrinterRegistration? @relation(fields: [printerRegistrationId], references: [id], onDelete: SetNull)

  orgId String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  licenseeId String?
  licensee Licensee? @relation(fields: [licenseeId], references: [id], onDelete: SetNull)

  assignedUserId String?
