generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  LICENSEE_ADMIN
  MANUFACTURER
  // New RBAC roles (preferred). Legacy roles remain for backward compatibility.
  PLATFORM_SUPER_ADMIN
  ORG_ADMIN
  MANUFACTURER_ADMIN
  MANUFACTURER_USER
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum QRStatus {
  DORMANT
  ACTIVE
  ALLOCATED
  ACTIVATED
  PRINTED
  REDEEMED
  BLOCKED
  SCANNED
}

enum QrAllocationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PrintJobStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TraceEventType {
  COMMISSIONED
  ASSIGNED
  PRINTED
  REDEEMED
  BLOCKED
}

enum PolicyAlertType {
  MULTI_SCAN
  GEO_DRIFT
  VELOCITY_SPIKE
  STUCK_BATCH
  AUTO_BLOCK_QR
  AUTO_BLOCK_BATCH
  POLICY_RULE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PolicyRuleType {
  DISTINCT_DEVICES
  MULTI_COUNTRY
  BURST_SCANS
  TOO_MANY_REPORTS
}

enum IncidentReportedBy {
  CUSTOMER
  LICENSEE
  ADMIN
}

enum IncidentContactMethod {
  EMAIL
  PHONE
  WHATSAPP
  NONE
}

enum IncidentType {
  COUNTERFEIT_SUSPECTED
  DUPLICATE_SCAN
  TAMPERED_LABEL
  WRONG_PRODUCT
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  NEW
  TRIAGED
  TRIAGE
  INVESTIGATING
  CONTAINMENT
  ERADICATION
  RECOVERY
  AWAITING_CUSTOMER
  AWAITING_LICENSEE
  MITIGATED
  RESOLVED
  CLOSED
  REOPENED
  REJECTED_SPAM
}

enum IncidentPriority {
  P1
  P2
  P3
  P4
}

enum IncidentResolutionOutcome {
  CONFIRMED_FRAUD
  NOT_FRAUD
  INCONCLUSIVE
}

enum IncidentActorType {
  CUSTOMER
  ADMIN
  SYSTEM
}

enum IncidentEventType {
  CREATED
  UPDATED_FIELDS
  STATUS_CHANGED
  ASSIGNED
  EMAIL_SENT
  NOTE_ADDED
  EVIDENCE_ADDED
  EXPORTED
}

enum IncidentCommDirection {
  OUTBOUND
  INBOUND
}

enum IncidentCommChannel {
  EMAIL
}

enum IncidentCommStatus {
  QUEUED
  SENT
  FAILED
}

enum IncidentHandoffStage {
  INTAKE
  REVIEW
  CONTAINMENT
  DOCUMENTATION
  RESOLUTION
  COMPLETE
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum NotificationChannel {
  WEB
  EMAIL
}

enum NotificationAudience {
  SUPER_ADMIN
  LICENSEE_ADMIN
  MANUFACTURER
  ALL
}

enum EvidenceRetentionJobStatus {
  RUNNING
  COMPLETED
  FAILED
  PREVIEW
}

enum AuthRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SecurityEventDeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum CompliancePackJobStatus {
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  name         String
  role         UserRole
  location     String?
  website      String?

  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id])

  licenseeId String?
  licensee   Licensee? @relation(fields: [licenseeId], references: [id])

  status   UserStatus @default(ACTIVE)
  isActive  Boolean   @default(true)
  disabledAt DateTime?
  disabledReason String?
  deletedAt DateTime?

  failedLoginAttempts Int @default(0)
  lockedUntil DateTime?
  lastLoginAt DateTime?

  assignedBatches        Batch[]        @relation("ManufacturerBatches")

  qrAllocationRequestsRequested QrAllocationRequest[] @relation("QrAllocationRequestedBy")
  qrAllocationRequestsApproved  QrAllocationRequest[] @relation("QrAllocationApprovedBy")
  qrAllocationRequestsRejected  QrAllocationRequest[] @relation("QrAllocationRejectedBy")

  allocationEventsCreated AllocationEvent[] @relation("AllocationEventCreatedBy")
  batchPrintPackTokensCreated BatchPrintPackToken[] @relation("BatchPrintPackTokenCreatedBy")
  batchPrintDownloads Batch[] @relation("BatchPrintPackDownloadedBy")
  printedQRCodes QRCode[] @relation("QRCodePrintedBy")
  printJobs PrintJob[] @relation("ManufacturerPrintJobs")
  traceEventsAsActor TraceEvent[] @relation("TraceEventUser")
  traceEventsAsManufacturer TraceEvent[] @relation("TraceEventManufacturer")
  policyAlertsAsManufacturer PolicyAlert[] @relation("PolicyAlertManufacturer")
  policyAlertsAcknowledged PolicyAlert[] @relation("PolicyAlertAcknowledgedBy")
  assignedIncidents Incident[] @relation("IncidentAssignedTo")
  incidentEvents IncidentEvent[] @relation("IncidentActorUser")
  incidentEvidence IncidentEvidence[] @relation("IncidentEvidenceUploadedBy")
  supportTicketsAssigned SupportTicket[] @relation("SupportTicketAssignedTo")
  supportTicketMessages SupportTicketMessage[] @relation("SupportTicketMessageAuthor")
  supportIssueReportsSubmitted SupportIssueReport[] @relation("SupportIssueReportSubmittedBy")
  notifications Notification[] @relation("UserNotifications")
  tenantFeatureFlagsUpdated TenantFeatureFlag[] @relation("TenantFeatureFlagUpdatedBy")
  evidenceRetentionPoliciesUpdated EvidenceRetentionPolicy[] @relation("EvidenceRetentionPolicyUpdatedBy")
  evidenceRetentionJobsStarted EvidenceRetentionJob[] @relation("EvidenceRetentionJobStartedBy")
  compliancePackJobsStarted CompliancePackJob[] @relation("CompliancePackJobStartedBy")
  routeTransitionMetrics RouteTransitionMetric[] @relation("RouteTransitionMetricUser")

  invitesCreated Invite[] @relation("InviteCreatedBy")
  invitesAccepted Invite[] @relation("InviteAcceptedBy")
  passwordResets PasswordReset[]
  refreshTokens RefreshToken[]
  adminMfaCredential AdminMfaCredential?
  authMfaChallenges AuthMfaChallenge[]
  authSessionRiskSignals AuthSessionRiskSignal[]
  policyRulesCreated PolicyRule[] @relation("PolicyRuleCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([licenseeId])
  @@index([role])
  @@index([isActive])
  @@index([status])
  @@index([lockedUntil])
}

model Organization {
  id       String @id @default(uuid())
  name     String
  isActive Boolean @default(true)

  licensee Licensee?
  users    User[]
  invites  Invite[]
  passwordResets PasswordReset[]
  refreshTokens  RefreshToken[]
  auditLogs AuditLog[]
  policyRules PolicyRule[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Licensee {
  id          String  @id @default(uuid())
  orgId       String  @unique
  organization Organization @relation(fields: [orgId], references: [id])

  name        String
  prefix      String  @unique
  description String?
  brandName   String?
  location    String?
  website     String?
  supportEmail String?
  supportPhone String?
  isActive    Boolean @default(true)
  suspendedAt DateTime?
  suspendedReason String?

  users          User[]
  qrRanges       QRRange[]
  batches        Batch[]
  qrCodes        QRCode[]
  qrAllocationRequests QrAllocationRequest[]
  allocationEvents     AllocationEvent[]
  qrScanLogs           QrScanLog[]
  traceEvents          TraceEvent[]
  securityPolicies     SecurityPolicy[]
  policyRules          PolicyRule[]
  policyAlerts         PolicyAlert[]
  incidents            Incident[]
  invites              Invite[]
  notifications        Notification[]
  tenantFeatureFlags   TenantFeatureFlag[]
  supportTickets       SupportTicket[]
  supportIssueReports  SupportIssueReport[]
  evidenceRetentionPolicy EvidenceRetentionPolicy?
  evidenceRetentionJobs EvidenceRetentionJob[]
  compliancePackJobs CompliancePackJob[]
  routeTransitionMetrics RouteTransitionMetric[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([orgId])
}

model QRRange {
  id         String   @id @default(uuid())
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  startCode  String
  endCode    String
  totalCodes Int
  usedCodes  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
}

model Batch {
  id         String   @id @default(uuid())
  name       String
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  // legacy optional direct assignment
  manufacturerId String?
  manufacturer   User?   @relation("ManufacturerBatches", fields: [manufacturerId], references: [id])

  startCode  String
  endCode    String
  totalCodes Int
  printedAt  DateTime?
  suspendedAt DateTime?
  suspendedReason String?
  printPackDownloadedAt DateTime?
  printPackDownloadedByUserId String?
  printPackDownloadedByUser   User? @relation("BatchPrintPackDownloadedBy", fields: [printPackDownloadedByUserId], references: [id])

  qrCodes        QRCode[]
  batchPrintPackTokens BatchPrintPackToken[]
  printJobs          PrintJob[]
  scanLogs            QrScanLog[]
  traceEvents         TraceEvent[]
  policyAlerts        PolicyAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
  @@index([manufacturerId])
  @@index([printedAt])
  @@index([printPackDownloadedAt])
  @@index([suspendedAt])
}

model PrintJob {
  id         String   @id @default(uuid())
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id])

  manufacturerId String
  manufacturer   User   @relation("ManufacturerPrintJobs", fields: [manufacturerId], references: [id])

  status     PrintJobStatus @default(PENDING)
  quantity   Int
  rangeStart String?
  rangeEnd   String?

  printLockTokenHash String @unique
  confirmedAt DateTime?
  createdAt   DateTime @default(now())

  qrCodes QRCode[]

  @@index([batchId])
  @@index([manufacturerId])
  @@index([status])
}

model QRCode {
  id         String   @id @default(uuid())
  code       String   @unique
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  // product batch removed
  scanLogs       QrScanLog[]

  status    QRStatus  @default(DORMANT)
  scannedAt DateTime?
  scanCount Int       @default(0)
  printedAt DateTime?
  printedByUserId String?
  printedByUser   User? @relation("QRCodePrintedBy", fields: [printedByUserId], references: [id])
  redeemedAt DateTime?
  redeemedDeviceFingerprint String?
  lastScanIp String?
  lastScanUserAgent String?
  lastScanDevice String?
  blockedAt DateTime?
  underInvestigationAt DateTime?
  underInvestigationReason String?
  tokenNonce String?
  tokenIssuedAt DateTime?
  tokenExpiresAt DateTime?
  tokenHash String?

  printJobId String?
  printJob   PrintJob? @relation(fields: [printJobId], references: [id])
  traceEvents TraceEvent[]
  policyAlerts PolicyAlert[]
  incidents Incident[]
  ownership Ownership?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
  @@index([batchId])
  @@index([status])
  @@index([printJobId])
  @@index([tokenHash])
  @@index([underInvestigationAt])
}

model Ownership {
  id        String   @id @default(cuid())
  qrCodeId  String   @unique
  qrCode    QRCode   @relation(fields: [qrCodeId], references: [id])
  userId    String?
  deviceTokenHash String?
  ipHash    String?
  userAgentHash String?
  claimSource String @default("USER")
  linkedAt DateTime?
  claimedAt DateTime @default(now())

  @@index([userId])
  @@index([deviceTokenHash])
  @@index([ipHash])
}

model QrScanLog {
  id         String   @id @default(uuid())
  code       String
  qrCodeId   String
  qrCode     QRCode   @relation(fields: [qrCodeId], references: [id])

  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  batchId String?
  batch   Batch? @relation(fields: [batchId], references: [id])
  // product batch removed

  status     QRStatus
  scannedAt  DateTime @default(now())
  isFirstScan Boolean @default(false)
  scanCount  Int?

  ipAddress String?
  userAgent String?
  device    String?
  latitude  Float?
  longitude Float?
  accuracy  Float?
  locationName String?
  locationCountry String?
  locationRegion String?
  locationCity String?

  incidents Incident[]

  @@index([licenseeId])
  @@index([batchId])
  @@index([code])
  @@index([scannedAt])
}

model BatchPrintPackToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id])

  createdByUserId String
  createdByUser   User @relation("BatchPrintPackTokenCreatedBy", fields: [createdByUserId], references: [id])

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([batchId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  orgId      String?
  organization Organization? @relation(fields: [orgId], references: [id])
  licenseeId String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  ipHash     String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([licenseeId])
  @@index([entityType])
  @@index([createdAt])
}

model Invite {
  id     String @id @default(uuid())
  orgId  String
  organization Organization @relation(fields: [orgId], references: [id])

  licenseeId String?
  licensee   Licensee? @relation(fields: [licenseeId], references: [id])

  email   String
  role    UserRole
  manufacturerId String?

  tokenHash String @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdByUserId String?
  createdByUser   User? @relation("InviteCreatedBy", fields: [createdByUserId], references: [id])

  acceptedByUserId String?
  acceptedByUser   User? @relation("InviteAcceptedBy", fields: [acceptedByUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([email])
  @@index([orgId])
  @@index([licenseeId])
  @@index([expiresAt])
  @@index([usedAt])
}

model PasswordReset {
  id String @id @default(uuid())

  orgId String?
  organization Organization? @relation(fields: [orgId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  createdIpHash String?
  userAgentHash String?

  @@index([userId])
  @@index([orgId])
  @@index([expiresAt])
  @@index([usedAt])
}

model RefreshToken {
  id String @id @default(uuid())

  orgId String?
  organization Organization? @relation(fields: [orgId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String @unique
  expiresAt DateTime

  createdAt DateTime @default(now())
  createdIpHash String?
  createdUserAgent String?

  lastUsedAt DateTime?
  revokedAt DateTime?
  revokedReason String?
  replacedByTokenHash String?

  @@index([userId])
  @@index([orgId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AdminMfaCredential {
  id String @id @default(uuid())

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  secretCiphertext String
  secretIv String
  secretTag String
  backupCodesHash String[]
  isEnabled Boolean @default(false)
  verifiedAt DateTime?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isEnabled])
  @@index([verifiedAt])
}

model AuthMfaChallenge {
  id String @id @default(uuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  ticketHash String @unique
  riskScore Int @default(0)
  riskLevel AuthRiskLevel @default(LOW)
  reasons String[]
  createdIpHash String?
  createdUserAgentHash String?

  createdAt DateTime @default(now())
  expiresAt DateTime
  consumedAt DateTime?

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([consumedAt])
}

model AuthSessionRiskSignal {
  id String @id @default(uuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  riskScore Int
  riskLevel AuthRiskLevel
  reasons String[]
  ipHash String?
  userAgentHash String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([riskLevel, createdAt])
}

model SecurityEventOutbox {
  id String @id @default(uuid())

  eventType String
  payload Json
  status SecurityEventDeliveryStatus @default(QUEUED)
  attempts Int @default(0)
  nextAttemptAt DateTime @default(now())
  lastError String?
  sentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([createdAt])
}

model CompliancePackJob {
  id String @id @default(uuid())

  licenseeId String?
  licensee Licensee? @relation(fields: [licenseeId], references: [id], onDelete: SetNull)

  status CompliancePackJobStatus @default(RUNNING)
  triggerType String
  periodFrom DateTime?
  periodTo DateTime?

  fileName String?
  storageKey String?
  integrityHash String?
  signatureAlgorithm String?
  summary Json?
  errorMessage String?

  startedByUserId String?
  startedByUser User? @relation("CompliancePackJobStartedBy", fields: [startedByUserId], references: [id], onDelete: SetNull)

  startedAt DateTime @default(now())
  finishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId, startedAt])
  @@index([status, startedAt])
  @@index([triggerType, startedAt])
  @@index([startedByUserId])
}

model QrAllocationRequest {
  id         String   @id @default(uuid())
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  requestedByUserId String
  requestedByUser   User @relation("QrAllocationRequestedBy", fields: [requestedByUserId], references: [id])

  quantity    Int?
  startNumber Int?
  endNumber   Int?
  batchName   String?

  status QrAllocationRequestStatus @default(PENDING)
  note   String?

  approvedByUserId String?
  approvedByUser   User? @relation("QrAllocationApprovedBy", fields: [approvedByUserId], references: [id])
  approvedAt       DateTime?

  rejectedByUserId String?
  rejectedByUser   User? @relation("QrAllocationRejectedBy", fields: [rejectedByUserId], references: [id])
  rejectedAt       DateTime?

  decisionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  allocationEvents AllocationEvent[]

  @@index([licenseeId])
  @@index([status])
}

model AllocationEvent {
  id         String   @id @default(uuid())
  licenseeId String
  licensee   Licensee @relation(fields: [licenseeId], references: [id])

  createdByUserId String?
  createdByUser   User? @relation("AllocationEventCreatedBy", fields: [createdByUserId], references: [id])

  requestId String?
  request   QrAllocationRequest? @relation(fields: [requestId], references: [id])

  source     String?
  startCode  String
  endCode    String
  totalCodes Int

  createdAt DateTime @default(now())

  @@index([licenseeId])
  @@index([requestId])
}

model TraceEvent {
  id         String       @id @default(uuid())
  eventType  TraceEventType
  licenseeId String
  licensee   Licensee     @relation(fields: [licenseeId], references: [id])

  batchId String?
  batch   Batch?   @relation(fields: [batchId], references: [id])

  qrCodeId String?
  qrCode   QRCode? @relation(fields: [qrCodeId], references: [id])

  manufacturerId String?
  manufacturer   User? @relation("TraceEventManufacturer", fields: [manufacturerId], references: [id])

  userId String?
  user   User? @relation("TraceEventUser", fields: [userId], references: [id])

  sourceAction String?
  details      Json?
  createdAt    DateTime @default(now())

  @@index([licenseeId])
  @@index([eventType])
  @@index([batchId])
  @@index([manufacturerId])
  @@index([qrCodeId])
  @@index([createdAt])
}

model SecurityPolicy {
  id String @id @default(uuid())

  licenseeId String?   @unique
  licensee   Licensee? @relation(fields: [licenseeId], references: [id])

  autoBlockEnabled         Boolean @default(true)
  autoBlockBatchOnVelocity Boolean @default(false)
  multiScanThreshold       Int     @default(2)
  geoDriftThresholdKm      Float   @default(300)
  velocitySpikeThresholdPerMin Int @default(80)
  stuckBatchHours          Int     @default(24)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([licenseeId])
}

model PolicyRule {
  id String @id @default(uuid())

  orgId String?
  organization Organization? @relation(fields: [orgId], references: [id])

  licenseeId String?
  licensee Licensee? @relation(fields: [licenseeId], references: [id])

  manufacturerId String?
  createdByUserId String?
  createdByUser   User? @relation("PolicyRuleCreatedBy", fields: [createdByUserId], references: [id])

  name String
  description String?
  ruleType PolicyRuleType
  isActive Boolean @default(true)

  threshold Int
  windowMinutes Int

  severity AlertSeverity @default(MEDIUM)
  autoCreateIncident Boolean @default(false)
  incidentSeverity IncidentSeverity?
  incidentPriority IncidentPriority?

  actionConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alerts PolicyAlert[]

  @@index([orgId])
  @@index([licenseeId])
  @@index([manufacturerId])
  @@index([isActive])
  @@index([ruleType])
}

model PolicyAlert {
  id         String         @id @default(uuid())
  licenseeId String
  licensee   Licensee       @relation(fields: [licenseeId], references: [id])

  alertType  PolicyAlertType
  severity   AlertSeverity @default(MEDIUM)
  message    String
  score      Int @default(0)

  policyRuleId String?
  policyRule   PolicyRule? @relation(fields: [policyRuleId], references: [id])

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  batchId String?
  batch   Batch? @relation(fields: [batchId], references: [id])

  qrCodeId String?
  qrCode   QRCode? @relation(fields: [qrCodeId], references: [id])

  manufacturerId String?
  manufacturer   User? @relation("PolicyAlertManufacturer", fields: [manufacturerId], references: [id])

  acknowledgedAt DateTime?
  acknowledgedByUserId String?
  acknowledgedByUser   User? @relation("PolicyAlertAcknowledgedBy", fields: [acknowledgedByUserId], references: [id])

  details   Json?
  createdAt DateTime @default(now())

  @@index([licenseeId])
  @@index([alertType])
  @@index([severity])
  @@index([policyRuleId])
  @@index([incidentId])
  @@index([batchId])
  @@index([manufacturerId])
  @@index([qrCodeId])
  @@index([acknowledgedAt])
  @@index([createdAt])
}

model Incident {
  id String @id @default(uuid())

  qrCodeId String?
  qrCode   QRCode? @relation(fields: [qrCodeId], references: [id])

  qrCodeValue String

  scanEventId String?
  scanEvent   QrScanLog? @relation(fields: [scanEventId], references: [id])

  licenseeId String?
  licensee   Licensee? @relation(fields: [licenseeId], references: [id])

  reportedBy IncidentReportedBy @default(CUSTOMER)
  customerName String?
  customerEmail String?
  customerPhone String?
  customerCountry String?
  preferredContactMethod IncidentContactMethod @default(NONE)
  consentToContact Boolean @default(false)

  incidentType IncidentType
  severity IncidentSeverity @default(MEDIUM)
  severityOverridden Boolean @default(false)
  description String
  photos String[]
  purchasePlace String?
  purchaseDate DateTime?
  productBatchNo String?
  locationLat Float?
  locationLng Float?
  locationName String?
  locationCountry String?
  locationRegion String?
  locationCity String?
  ipHash String?
  userAgentHash String?
  deviceFingerprintHash String?

  status IncidentStatus @default(NEW)
  priority IncidentPriority @default(P3)
  assignedToUserId String?
  assignedToUser User? @relation("IncidentAssignedTo", fields: [assignedToUserId], references: [id])
  slaDueAt DateTime?
  tags String[]
  internalNotes String?
  resolutionSummary String?
  resolutionOutcome IncidentResolutionOutcome?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events IncidentEvent[]
  communications IncidentCommunication[]
  evidence IncidentEvidence[]
  handoff IncidentHandoff?
  supportTicket SupportTicket?
  evidenceFingerprints IncidentEvidenceFingerprint[]
  notifications Notification[]

  policyAlerts PolicyAlert[]

  @@index([qrCodeId])
  @@index([qrCodeValue])
  @@index([scanEventId])
  @@index([licenseeId])
  @@index([status])
  @@index([severity])
  @@index([priority])
  @@index([createdAt])
  @@index([assignedToUserId])
}

model IncidentEvent {
  id String @id @default(uuid())

  incidentId String
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  actorType IncidentActorType
  actorUserId String?
  actorUser User? @relation("IncidentActorUser", fields: [actorUserId], references: [id])
  eventType IncidentEventType
  eventPayload Json?
  createdAt DateTime @default(now())

  @@index([incidentId])
  @@index([actorType])
  @@index([eventType])
  @@index([createdAt])
  @@index([actorUserId])
}

model IncidentCommunication {
  id String @id @default(uuid())

  incidentId String
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  direction IncidentCommDirection
  channel IncidentCommChannel @default(EMAIL)
  toAddress String
  subject String
  bodyPreview String
  attemptedFrom String?
  usedFrom String?
  replyTo String?
  providerMessageId String?
  errorMessage String?
  status IncidentCommStatus @default(QUEUED)
  createdAt DateTime @default(now())

  @@index([incidentId])
  @@index([status])
  @@index([createdAt])
}

model IncidentEvidence {
  id String @id @default(uuid())

  incidentId String
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  fileUrl String?
  storageKey String?
  fileType String?
