########################################
# MSCQR - BACKEND ENV REFERENCE #
########################################

############
# REQUIRED #
############

# PostgreSQL connection string.
# Example:
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
DATABASE_URL=

# Main application JWT secret (required for auth/session/security hashing fallback).
JWT_SECRET=
# Preferred dual-slot JWT rotation.
JWT_SECRET_CURRENT=
JWT_SECRET_PREVIOUS=

##################
# CORE RUNTIME   #
##################

PORT=4000
NODE_ENV=development

# Comma-separated origins allowed by CORS.
# Example:
# CORS_ORIGIN=http://localhost:8080,http://localhost:8081
CORS_ORIGIN=http://localhost:8080

# Cookie hardening.
# Set COOKIE_SECURE=true in production HTTPS environments.
COOKIE_SECURE=false
# Optional cookie domain, only if needed:
COOKIE_DOMAIN=

############################
# PUBLIC WEB URL SETTINGS  #
############################

# Customer scan landing URL base.
# Example production: https://www.mscqr.com
PUBLIC_SCAN_WEB_BASE_URL=http://localhost:8080

# Customer verify page URL base (used in links and incident workflows).
# Example production: https://www.mscqr.com
PUBLIC_VERIFY_WEB_BASE_URL=http://localhost:8080

# Admin app base URL used for invite/password links.
# Example production: https://www.mscqr.com
PUBLIC_ADMIN_WEB_BASE_URL=http://localhost:8080
WEB_APP_BASE_URL=http://localhost:8080

# Optional explicit API base used in invite emails for connector download links.
# Leave empty when the frontend serves /api on the same host as WEB_APP_BASE_URL.
PUBLIC_API_BASE_URL=

#############################
# QR SIGNING AND TOKEN FLOW #
#############################

# Preferred: Ed25519 keys.
# If these are not set, QR_SIGN_HMAC_SECRET is used as fallback.
QR_SIGN_PRIVATE_KEY=
QR_SIGN_PUBLIC_KEY=

# Fallback signing secret (use only if asymmetric keys are not configured).
QR_SIGN_HMAC_SECRET=
QR_SIGN_HMAC_SECRET_CURRENT=
QR_SIGN_HMAC_SECRET_PREVIOUS=

# Token expiry in days for generated print tokens.
QR_TOKEN_EXP_DAYS=365

# Rate limit for scan endpoint (requests/minute per key).
SCAN_RATE_LIMIT_PER_MIN=60
# Rate limit for public verify-by-code endpoint (requests/minute per key).
PUBLIC_VERIFY_RATE_LIMIT_PER_MIN=45
# Read-only public manifest checks.
PUBLIC_CONNECTOR_RATE_LIMIT_PER_MIN=120
PUBLIC_CONNECTOR_DOWNLOAD_RATE_LIMIT_PER_5MIN=60
PUBLIC_STATUS_RATE_LIMIT_PER_MIN=240
PUBLIC_TELEMETRY_RATE_LIMIT_PER_MIN=120
SUPPORT_TICKET_TRACK_RATE_LIMIT_PER_15MIN=30
# Rate limits for public verify-side form posts.
VERIFY_REPORT_RATE_LIMIT_PER_15MIN=20
VERIFY_FEEDBACK_RATE_LIMIT_PER_15MIN=30

# Manufacturer direct-print security controls.
PRINT_JOB_LOCK_TTL_MINUTES=45
DIRECT_PRINT_TOKEN_TTL_SECONDS=90
DIRECT_PRINT_MAX_BATCH=250
PRINT_AGENT_HEARTBEAT_TTL_SECONDS=35
# Dedicated signing secret for printer SSE keepalive signatures.
# Rotate independently from JWT_SECRET.
PRINTER_SSE_SIGN_SECRET=
PRINTER_SSE_SIGN_SECRET_CURRENT=
PRINTER_SSE_SIGN_SECRET_PREVIOUS=
NOTIFICATION_REALTIME_ALERTS_EMAIL_ENABLED=true
NOTIFICATION_REALTIME_ALERT_EMAIL_SUBJECT_PREFIX=[MSCQR Real-time Alert]

# Required release-time identity for signing the bundled macOS executables.
# Example: Developer ID Application: Example Company (TEAMID1234)
MACOS_CONNECTOR_APP_SIGN_IDENTITY=

# Optional release-time identity for signing the packaged macOS connector.
# Example: Developer ID Installer: Example Company (TEAMID1234)
MACOS_CONNECTOR_SIGN_IDENTITY=

# Optional one-command notarization for the packaged macOS connector.
# Preferred: create a keychain profile first, then set only MACOS_CONNECTOR_NOTARY_PROFILE.
# Example:
# xcrun notarytool store-credentials mscqr-connector --apple-id you@example.com --team-id TEAMID1234 --password app-specific-password
MACOS_CONNECTOR_NOTARY_PROFILE=

# Alternative direct credentials for xcrun notarytool submit.
# Set all three together when not using MACOS_CONNECTOR_NOTARY_PROFILE.
MACOS_CONNECTOR_NOTARY_APPLE_ID=
MACOS_CONNECTOR_NOTARY_TEAM_ID=
MACOS_CONNECTOR_NOTARY_PASSWORD=

# Optional strict mode for release packaging.
# true = fail the macOS release when signing/notarization is missing and do not publish a blocked Mac installer
# false = create the package locally, but keep non-notarized macOS artifacts out of manifest.json
MACOS_CONNECTOR_REQUIRE_NOTARIZATION=true

#####################################
# SECURITY HASHING AND DATA SAFETY  #
#####################################

# Recommended: explicit salts/secrets instead of relying on JWT_SECRET fallback.
# These let you rotate hashing/signing secrets without rotating every auth token.
IP_HASH_SALT=
IP_HASH_SALT_CURRENT=
IP_HASH_SALT_PREVIOUS=
TOKEN_HASH_SECRET=
TOKEN_HASH_SECRET_CURRENT=
TOKEN_HASH_SECRET_PREVIOUS=
SCAN_FINGERPRINT_SECRET=
INCIDENT_HASH_SALT=
INCIDENT_HASH_SALT_CURRENT=
INCIDENT_HASH_SALT_PREVIOUS=

# Audit log privacy switch:
# false = store hashed IP only
# true  = store raw IP as well (only if policy/legal allows)
AUDIT_LOG_STORE_RAW_IP=false

# Optional retry worker for customer-facing audit durability when direct audit writes fail.
AUDIT_OUTBOX_POLL_MS=5000
AUDIT_OUTBOX_BATCH_SIZE=25

##########################
# EMAIL / NOTIFICATIONS  #
##########################

# SMTP transport
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional aliases supported by code (leave empty unless your provider uses these names).
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_USER=
EMAIL_PASS=
MAIL_USER=
MAIL_PASS=
MAIL_PASSWORD=

# Local testing mode - email payload is captured instead of sending real email.
EMAIL_USE_JSON_TRANSPORT=false

# Comma-separated super admin alert recipients for incident notifications.
SUPERADMIN_ALERT_EMAILS=

# Preferred superadmin/system mailbox used in auth/incident emails (reply-to/system mode).
# Example: administration@mscqr.com
SUPER_ADMIN_EMAIL=

##############################
# CUSTOMER VERIFY AUTH FLOW  #
##############################

# Secrets for customer OTP and customer verify token.
# If empty, JWT_SECRET fallback is used.
CUSTOMER_VERIFY_OTP_SECRET=
CUSTOMER_VERIFY_TOKEN_SECRET=

# OTP and token lifetime settings.
CUSTOMER_VERIFY_OTP_TTL_MINUTES=10
CUSTOMER_VERIFY_TOKEN_TTL_HOURS=720
# Optional dedicated secrets for customer social sign-in state / exchange tickets.
CUSTOMER_VERIFY_OAUTH_STATE_SECRET=
CUSTOMER_VERIFY_OAUTH_EXCHANGE_SECRET=
# Optional dedicated WebAuthn challenge TTL for customer passkeys.
# Falls back to AUTH_WEBAUTHN_CHALLENGE_TTL_MINUTES when unset.
CUSTOMER_WEBAUTHN_CHALLENGE_TTL_MINUTES=5

# Optional real social identity providers for the customer verify journey.
# Leave unset to hide a provider from the public verify page.
CUSTOMER_VERIFY_GOOGLE_CLIENT_ID=
CUSTOMER_VERIFY_GOOGLE_CLIENT_SECRET=

CUSTOMER_VERIFY_APPLE_CLIENT_ID=
CUSTOMER_VERIFY_APPLE_TEAM_ID=
CUSTOMER_VERIFY_APPLE_KEY_ID=
# Multi-line Apple private keys can be pasted with \n escapes.
CUSTOMER_VERIFY_APPLE_PRIVATE_KEY=

CUSTOMER_VERIFY_X_CLIENT_ID=
CUSTOMER_VERIFY_X_CLIENT_SECRET=

################################
# INCIDENT AND ABUSE CONTROLS  #
################################

INCIDENT_RATE_LIMIT_WINDOW_MS=3600000
INCIDENT_RATE_LIMIT_MAX_PER_KEY=8
INCIDENT_SPAM_MAX_PER_HOUR=5

INCIDENT_UPLOAD_MAX_BYTES=5242880
INCIDENT_UPLOAD_MAX_FILES=4
INCIDENT_EVIDENCE_MAX_BYTES=8388608

# Captcha gate for public incident submit
INCIDENT_CAPTCHA_ENABLED=false
INCIDENT_CAPTCHA_BYPASS_TOKEN=
RECAPTCHA_SECRET_KEY=

#########################
# GEO / POLICY SETTINGS #
#########################

GEO_REVERSE_ENABLED=true
GEO_REVERSE_PROVIDER=nominatim
GEO_REVERSE_TIMEOUT_MS=1200

POLICY_RAPID_REPEAT_MINUTES=30
POLICY_RAPID_REPEAT_DISTANCE_KM=80

# Allocation transaction settings for large QR range provisioning.
ALLOCATION_TX_TIMEOUT_MS=120000
ALLOCATION_TX_MAX_WAIT_MS=15000

##########################
# GOVERNANCE / COMPLIANCE#
##########################

APP_NAME=MSCQR
DPO_EMAIL=
SUPER_ADMIN_EMAIL=
HOSTING_PROVIDER=
RETENTION_DAYS=180
COMPLIANCE_PACK_SCHEDULER_ENABLED=false
COMPLIANCE_PACK_SCHEDULER_HOUR_UTC=2
COMPLIANCE_PACK_SCHEDULER_MINUTE_UTC=0

#################
# LOGGING       #
#################

SERVICE_NAME=mscqr-backend
# Optional deploy metadata propagated to logs, /version, and health payloads.
GIT_SHA=
LOG_LEVEL=info
# LOG_FORMAT=json enables structured logs.
LOG_FORMAT=
# Legacy toggle also supported:
LOG_JSON=false

#################
# OBSERVABILITY #
#################

SENTRY_ENVIRONMENT=development
SENTRY_DSN=
SENTRY_DSN_BACKEND=
SENTRY_TRACES_SAMPLE_RATE=0

#############################
# SIEM / SOAR INTEGRATION   #
#############################

# SIEM sink: webhook (default) or stdout for local debug.
SIEM_SINK_MODE=webhook
SIEM_WEBHOOK_URL=
SIEM_WEBHOOK_SECRET=
SIEM_OUTBOX_POLL_MS=5000
SIEM_OUTBOX_BATCH_SIZE=20

# SOAR auto-containment rules.
SOAR_AUTO_CONTAINMENT_ENABLED=true
SOAR_LOOKBACK_HOURS=24
SOAR_BATCH_SUSPEND_THRESHOLD=3
SOAR_ALLOW_ORG_SUSPEND=false
SOAR_ORG_SUSPEND_THRESHOLD=10

#############################
# OAUTH / INVITE COMPAT     #
#############################

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_CALLBACK_URL=

#############################
# ADMIN MFA / LOGIN RISK    #
#############################

# Dedicated encryption key for MFA secret storage.
# Required in production. Local development can fall back to JWT_SECRET.
AUTH_MFA_ENCRYPTION_KEY=
# Admin/staff account email verification link lifetime.
EMAIL_VERIFICATION_TTL_HOURS=24
# Leave both disabled in production after the cookie-only auth rollout.
AUTH_LEGACY_TOKEN_RESPONSE_ENABLED=false
AUTH_SSE_QUERY_TOKEN_ENABLED=false
# TOTP issuer label.
MFA_TOTP_ISSUER=MSCQR
# MFA challenge timeout and backup code count.
AUTH_MFA_CHALLENGE_TTL_MINUTES=5
AUTH_MFA_BACKUP_CODE_COUNT=8
# Session risk thresholds (0-100).
AUTH_RISK_STEPUP_THRESHOLD=55
AUTH_RISK_BLOCK_THRESHOLD=85

##################################
# OPTIONAL BUILD METADATA FIELDS #
##################################

GIT_SHA=
GITHUB_SHA=
COMMIT_SHA=
RENDER_GIT_COMMIT=
VERCEL_GIT_COMMIT_SHA=
