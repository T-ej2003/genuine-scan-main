{
  "name": "mscqr-backend",
  "version": "1.0.0",
  "description": "Backend API for MSCQR Licensee Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "prisma generate && tsx watch src/index.ts",
    "auth:mfa:break-glass": "tsx scripts/break-glass-mfa-reset.ts",
    "analytics:refresh-rollups": "tsx scripts/refresh-analytics-rollups.ts",
    "data:backfill-batch-lineage": "tsx scripts/backfill-batch-lineage.ts",
    "data:backfill-trace-events": "tsx scripts/backfill-trace-events.ts",
    "storage:migrate-local-uploads": "tsx scripts/migrate-local-uploads-to-object-storage.ts",
    "build": "tsc",
    "mock:printer": "node mock-printer/server.js",
    "print:agent": "node dist/local-print-agent/index.js",
    "print:agent:dev": "tsx src/local-print-agent/index.ts",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "test": "export NODE_ENV=test JWT_SECRET=test-jwt-secret; npm run build && node tests/qrService.test.js && node tests/scanSecurity.test.js && node tests/duplicateRiskEngine.test.js && node tests/incidentMvp.test.js && node tests/incidentPdfExport.test.js && node tests/compliancePackService.test.js && node tests/printPayloadService.test.js && node tests/networkIppPrinting.test.js && node tests/printJobOperationalView.test.js && node tests/printerProfileDiscovery.test.js && node tests/printerUserFacingErrors.test.js && node tests/connectorReleaseService.test.js && node tests/localPrintAgentCups.test.js && node tests/localPrintAgentWindows.test.js && node tests/pdfLabelRender.test.js && node tests/publicVerifyRateLimit.test.js && node tests/securityHardening.test.js && node tests/notificationVisibility.test.js && node tests/publicScanFallback.test.js && node tests/publicScanActorForeignKeyFallback.test.js && node tests/publicScanStrictFailClosed.test.js && node tests/publicVerifyStrictFailClosed.test.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "connector:release": "node local-print-agent/packaging/build-connector-release.mjs",
    "print:agent:install:macos": "sh local-print-agent/install/macos/install-launch-agent.sh",
    "print:agent:uninstall:macos": "sh local-print-agent/install/macos/uninstall-launch-agent.sh",
    "print:agent:install:linux": "sh local-print-agent/install/linux/install-systemd-user.sh",
    "print:agent:uninstall:linux": "sh local-print-agent/install/linux/uninstall-systemd-user.sh",
    "print:agent:install:windows": "powershell -ExecutionPolicy Bypass -File local-print-agent/install/windows/install-startup-task.ps1",
    "print:agent:uninstall:windows": "powershell -ExecutionPolicy Bypass -File local-print-agent/install/windows/uninstall-startup-task.ps1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@prisma/client": "^5.10.0",
    "@sentry/node": "^10.45.0",
    "@types/pdfkit": "^0.17.5",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.2.1",
    "file-saver": "^2.0.5",
    "ioredis": "^5.10.1",
    "ipp": "^2.0.1",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^7.0.3",
    "@yao-pkg/pkg": "^6.14.1",
    "prisma": "^5.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
